{
  "extends": [
    "@my/configs.js/tsconfig.base.json",
    "@my/configs.js/tsconfig.base.node@24.json"
  ],
  "include": ["**/eslint.config.*", "**/prettier.config.*", "**/vite.config.ts"],

  "compilerOptions": {
    // Without this `*.tsbuildinfo` file will be created on project root.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tooling.tsbuildinfo",

    "composite": true,
    "noEmit": true,

    "allowJs": true
  }
}
